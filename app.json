{
  "expo": {
    "name": "AppUsuarios",
    "slug": "AppUsuarios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LogoG1.png",
    "scheme": "appusuarios",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LogoG1.png",
        "backgroundColor": "#1a3a5c"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.btech.appusuarios"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/LogoG1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LogoG1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a3a5c",
          "dark": {
            "backgroundColor": "#1a3a5c"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1d186db-b1ab-470b-8535-59f84269820a"
      }
    }
  }
}
